<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_medical_attestation_template_tree" model="ir.ui.view">
        <field name="name">medical.attestation.template.tree</field>
        <field name="model">medical.attestation.template</field>
        <field name="arch" type="xml">
            <list string="Modèles d'attestations">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="title"/>
            </list>
        </field>
    </record>

    <record id="view_medical_attestation_template_form" model="ir.ui.view">
        <field name="name">medical.attestation.template.form</field>
        <field name="model">medical.attestation.template</field>
        <field name="arch" type="xml">
            <form string="Modèle d'attestation">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Ex: Certificat médical standard"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="title" placeholder="Ex: Certificat médical d'aptitude"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <separator string="Contenu par défaut"/>
                    <field name="content" placeholder="Rédigez ici le texte par défaut de l'attestation. Ce texte sera pré-rempli lors de la création d'une attestation basée sur ce modèle. Le médecin pourra ensuite le modifier selon le patient."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_medical_attestation_template" model="ir.actions.act_window">
        <field name="name">Modèles d'attestations</field>
        <field name="res_model">medical.attestation.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
