<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_secretary_all_appointments" model="ir.rule">
            <field name="name">Secretary: All Appointments</field>
            <field name="model_id" ref="model_medical_appointment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('medical_base.group_medical_secretary'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="rule_doctor_own_appointments" model="ir.rule">
            <field name="name">Doctor: Own Appointments</field>
            <field name="model_id" ref="model_medical_appointment"/>
            <field name="domain_force">['|', ('doctor_id.user_id', '=', user.id), ('doctor_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('medical_base.group_medical_doctor'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        <record id="rule_admin_all_appointments" model="ir.rule">
            <field name="name">Admin: All Appointments</field>
            <field name="model_id" ref="model_medical_appointment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_erp_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
